# Copy this to .env and fill in real values.

# ─── REQUIRED ───────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here

# ─── BOT IDENTITY ────────────────────────────────────────────────────────────
BOT_NAME=Vast Bot
BOT_AVATAR_URL=
PREFIX=!
OWNER_ID=0
STATUS_TYPE=playing       # playing | watching | listening
STATUS_TEXT=Vast.org

# ─── DATABASE ────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite+aiosqlite:///vast_bot.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/vastbot

# ─── LEVELING ────────────────────────────────────────────────────────────────
TEXT_XP_MIN=15
TEXT_XP_MAX=25
TEXT_XP_COOLDOWN=60
VOICE_XP_RATE=10
LEADERBOARD_BASE_URL=https://vast.org/leaderboard

# ─── MODERATION ──────────────────────────────────────────────────────────────
RAID_JOIN_THRESHOLD=10
RAID_JOIN_WINDOW=10
RAID_ACCOUNT_AGE_DAYS=7
MAX_MENTIONS=5
MAX_EMOJIS=10
STRIKE_WARN=1
STRIKE_MUTE=3
STRIKE_KICK=5

# ─── SOCIAL MEDIA API KEYS ───────────────────────────────────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
YOUTUBE_API_KEY=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=vast-bot/1.0

# ─── AI GUARD (Google Cloud) ─────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=

# ─── MUSIC (Lavalink) ────────────────────────────────────────────────────────
LAVALINK_HOST=127.0.0.1
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass

# ─── ECONOMY ─────────────────────────────────────────────────────────────────
STARTING_BALANCE=100
DAILY_COINS=50

# ─── STARBOARD ───────────────────────────────────────────────────────────────
STARBOARD_THRESHOLD=3
